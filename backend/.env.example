NODE_ENV=development
HOST=127.0.0.1
PORT=3005
PUBLIC_BASE_URL=http://localhost:3005
DATABASE_URL=mysql://bnbu_app:replace-with-a-strong-password@127.0.0.1:3306/bnbu_kuan_week2
# Docker Compose only: raw password initializes MySQL; URLENCODED is the same
# password percent-encoded for DATABASE_URL (for example # becomes %23).
MYSQL_PASSWORD=replace-with-a-strong-password
MYSQL_PASSWORD_URLENCODED=replace-with-a-strong-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-strong-password
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ISSUER=bnbu-sports
JWT_AUDIENCE=bnbu-student
JWT_TTL=12h
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TRUST_PROXY=1
LOG_LEVEL=info
GLOBAL_RATE_LIMIT_PER_15_MIN=60000
LOGIN_RATE_LIMIT_PER_15_MIN=20
STORAGE_DRIVER=local
UPLOAD_LOCAL_DIR=./uploads
UPLOAD_MAX_REQUEST_BYTES=120000000
UPLOAD_MAX_CONCURRENT=2
UNCLAIMED_UPLOAD_TTL_HOURS=24
UNCLAIMED_UPLOAD_CLEANUP_BATCH=100
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=bnbu-sports-1443273655
COS_REGION=ap-guangzhou
COS_SIGNED_URL_TTL_SECONDS=900
SEED_STUDENT_ACCOUNT=demo-student
SEED_STUDENT_EMAIL=demo.student@example.invalid
SEED_STUDENT_PASSWORD=replace-before-running-seed
