<?xml version="1.0" encoding="utf-8"?>
<!-- Production/release policy: system-trusted TLS only, with no cleartext fallback. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
